# Geopolitical Intelligence Platform - Environment Configuration

# Application
DEBUG=false
ENVIRONMENT=production
SECRET_KEY=change-me-in-production-this-is-placeholder

# Database - PostgreSQL
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=geopolitical_intel

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Redis
REDIS_URL=redis://localhost:6379/0

# RSS/API Ingestion
RSS_FETCH_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_FETCH=50
REQUEST_TIMEOUT_SECONDS=30

# Risk Governance
SAFE_MODE_ENABLED=false
RISK_THRESHOLD=40

# OpenAI / LLM
OPENAI_API_KEY=REPLACE_WITH_SECURE_KEY
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4000

# Video Production
VIDEO_OUTPUT_DIR=./output/videos
TTS_ENGINE=elevenlabs
ELEVENLABS_API_KEY=REPLACE_WITH_SECURE_KEY

# Avatar / Lip-Sync (Local SadTalker = Free, Open-Source)
AVATAR_ENGINE=local
SADTALKER_DIR=../sadtalker
SADTALKER_DOCKER_PATH=/app/sadtalker
DID_API_KEY=
HEYGEN_API_KEY=
DEFAULT_PRESENTER_IMAGE=./assets/presenter.png

# Audit & Logging
AUDIT_LOG_RETENTION_DAYS=365
LOG_LEVEL=INFO

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
