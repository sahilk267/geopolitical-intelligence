# Geopolitical Intelligence Platform - Environment Configuration

# Application
DEBUG=false
ENVIRONMENT=production
SECRET_KEY=REPLACE_WITH_SECURE_KEY
ENCRYPTION_KEY=REPLACE_WITH_SECURE_KEY

# Initial administrator account
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
DEFAULT_ADMIN_FULL_NAME=System Administrator

# Database - PostgreSQL
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=geopolitical_intel

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Redis
REDIS_URL=redis://localhost:6379/0

# RSS/API Ingestion
RSS_FETCH_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_FETCH=50
REQUEST_TIMEOUT_SECONDS=30

# Risk Governance
SAFE_MODE_ENABLED=false
RISK_THRESHOLD=40

# AI/LLM Integration
AI_PROVIDER=ollama  # Set to ollama or gemini depending on available provider
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
STABLE_DIFFUSION_URL=http://host.docker.internal:7860
OPENAI_API_KEY=REPLACE_WITH_SECURE_KEY
GEMINI_API_KEY=REPLACE_WITH_SECURE_KEY
LLM_MODEL=gemini-1.5-flash
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4000

# Video Production
VIDEO_OUTPUT_DIR=./output/videos
TTS_ENGINE=elevenlabs
ELEVENLABS_API_KEY=REPLACE_WITH_SECURE_KEY

# Avatar / Lip-Sync (Local SadTalker = Free, Open-Source)
AVATAR_ENGINE=local
SADTALKER_DIR=../sadtalker
SADTALKER_DOCKER_PATH=/app/sadtalker
DID_API_KEY=
HEYGEN_API_KEY=
DEFAULT_PRESENTER_IMAGE=./assets/presenter.png

# Audit & Logging
AUDIT_LOG_RETENTION_DAYS=365
LOG_LEVEL=INFO

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Social Distribution
TELEGRAM_BOT_TOKEN=REPLACE_WITH_SECURE_KEY
TELEGRAM_CHAT_ID=REPLACE_WITH_SECURE_ID
YOUTUBE_CLIENT_ID=REPLACE_WITH_SECURE_KEY
YOUTUBE_CLIENT_SECRET=REPLACE_WITH_SECURE_KEY
TWITTER_API_KEY=REPLACE_WITH_SECURE_KEY
TWITTER_API_SECRET=REPLACE_WITH_SECURE_KEY
TWITTER_ACCESS_TOKEN=REPLACE_WITH_SECURE_KEY
TWITTER_ACCESS_SECRET=REPLACE_WITH_SECURE_KEY
DISCORD_WEBHOOK_URL=REPLACE_WITH_SECURE_KEY
